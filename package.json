{
  "name": "nt-cli",
  "version": "1.0.0",
  "description": "Nortlin CLI - Package manager for nortlin-packages",
  "main": "bin/nt.js",
  "bin": {
    "nt": "./bin/nt.js"
  },
  "type": "module",
  "scripts": {
    "start": "node bin/nt.js",
    "build": "pkg . --out-path=dist/",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": ["cli", "package-manager", "nortlin", "nt", "installer"],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "preferGlobal": true,
  "pkg": {
    "scripts": [
      "bin/**/*.js",
      "src/**/*.js"
    ],
    "targets": [
      "node20-win-x64",
      "node20-linux-x64",
      "node20-macos-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cli-progress": "^3.12.0",
    "tar": "^6.2.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
